# ─────────────────────────────────────────────
# Aura Waitlist — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# 1. Google Sheets — Service Account JSON (single line, minified)
#    Steps:
#      a) Google Cloud Console → Enable "Google Sheets API"
#      b) IAM & Admin → Service Accounts → Create → Download JSON key
#      c) Minify the JSON to a single line (jsonformatter.org/json-minifier)
#      d) Share your Google Sheet with the service account client_email (Editor)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# 2. Google Sheet ID
#    Found in the sheet URL: https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
#    Sheet must have: Sheet1 with columns A=Tidspunkt, B=Navn, C=Email
GOOGLE_SHEET_ID=your_google_sheet_id_here